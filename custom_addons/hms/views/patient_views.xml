<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hms_patient_list" model="ir.ui.view">
        <field name="name">hms.patient.list</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <list string="Patients">
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="birth_date"/>
                <field name="age"/>
                <field name="blood_type"/>
                <field name="pcr"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_hms_patient_form" model="ir.ui.view">
        <field name="name">hms.patient.form</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'size': [128, 128]}"/>

                    <div class="oe_title">
                        <label for="first_name" string="Patient Name"/>
                        <h1>
                            <field name="first_name" placeholder="First Name"/>
                            <field name="last_name" placeholder="Last Name"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Personal Info">
                            <field name="birth_date"/>
                            <field name="age"readonly="1"/> 
                            <field name="email"/>
                            <field name="address"/>
                        </group>
                        <group string="Medical Info">
                            <field name="blood_type"/>
                            <field name="pcr"/>
                            <field name="cr_ratio"/>
                        </group>
                    </group>

                    <group string="Hospital Assignment Setup">
                        <group>
                            <field name="department_id"/>
                            <field name="department_capacity"/>
                        </group>
                        <group groups="hms.group_hms_manager">
                            <field name="doctor_ids" widget="many2many_tags" readonly="not department_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Medical History" invisible="age &lt; 50">
                            <field name="history" placeholder="Enter patient medical history here..."/>
                        </page>
                        <page string="Log History Data">
                            <field name="log_ids">
                                <list>
                                    <field name="create_uid"/>
                                    <field name="create_date"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hms_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hms.patient</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>